@model List<RentACar.Application.DTOs.CarDto>
@{
    ViewData["Title"] = "Arac Kiralama";
}

<!-- HERO -->
<section class="hero-section d-flex align-items-center">
    <div class="container py-5">
        <div class="row align-items-center g-5">
            <div class="col-lg-5">
                <p class="text-uppercase fw-bold mb-2" style="color:var(--primary);letter-spacing:2px;font-size:.8rem">Turkiye'nin Guvenilir Kiralama Platformu</p>
                <h1 class="display-4 text-white mb-3" style="font-weight:900;line-height:1.1">
                    Hayalindeki<br><span style="color:var(--primary)">Arabay&#305;</span> Kirala
                </h1>
                <p class="text-white-50 mb-4">Premium'dan ekonomiye 18 farkl&#305; arac. An&#305;nda rezervasyon, ucretsiz iptal.</p>
                <div class="d-flex gap-4">
                    <div class="text-center"><div class="fw-bold text-white fs-4">18+</div><div class="text-white-50 small">Arac</div></div>
                    <div class="border-start border-secondary"></div>
                    <div class="text-center"><div class="fw-bold text-white fs-4">7/24</div><div class="text-white-50 small">Destek</div></div>
                    <div class="border-start border-secondary"></div>
                    <div class="text-center"><div class="fw-bold text-white fs-4">%100</div><div class="text-white-50 small">Guvenli</div></div>
                </div>
            </div>
            <div class="col-lg-7">
                <div class="search-box">
                    <div class="d-flex gap-2 mb-4">
                        <button class="search-tab active" id="tab-daily" onclick="setTab('daily')"><i class="bi bi-calendar-day me-1"></i>Gunluk</button>
                        <button class="search-tab" id="tab-monthly" onclick="setTab('monthly')"><i class="bi bi-calendar-month me-1"></i>Aylik</button>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="search-label">Alis Lokasyonu</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0"><i class="bi bi-geo-alt text-muted"></i></span>
                                <input type="text" class="form-control border-start-0" placeholder="Sehir veya havalimani">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="search-label">Iade Lokasyonu</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0"><i class="bi bi-geo-alt-fill text-muted"></i></span>
                                <input type="text" class="form-control border-start-0" placeholder="Sehir veya havalimani">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="search-label">Alis Tarihi</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0"><i class="bi bi-calendar3 text-muted"></i></span>
                                <input type="date" class="form-control border-start-0" id="startDate">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="search-label">Iade Tarihi</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0"><i class="bi bi-calendar3-fill text-muted"></i></span>
                                <input type="date" class="form-control border-start-0" id="endDate">
                            </div>
                        </div>
                        <div class="col-12">
                            <button class="btn w-100 fw-bold" style="background:var(--primary);color:#fff;height:52px;font-size:1rem;border-radius:4px;" onclick="scrollToCars()">
                                <i class="bi bi-search me-2"></i>ARAC ARA
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- CATEGORY FILTER -->
<div style="background:#fff;border-bottom:1px solid #e2e8f0;box-shadow:0 2px 8px rgba(0,0,0,.06);position:sticky;top:0;z-index:100">
    <div class="container">
        <div class="d-flex gap-2 py-3 overflow-auto">
            <button class="cat-btn active" onclick="filterCars(this,'all')"><i class="bi bi-grid me-1"></i>Tumu</button>
            <button class="cat-btn" onclick="filterCars(this,'Premium')"><i class="bi bi-star me-1"></i>Premium</button>
            <button class="cat-btn" onclick="filterCars(this,'SUV')"><i class="bi bi-truck me-1"></i>SUV</button>
            <button class="cat-btn" onclick="filterCars(this,'Van')"><i class="bi bi-bus-front me-1"></i>Van</button>
            <button class="cat-btn" onclick="filterCars(this,'Compact')"><i class="bi bi-car-front me-1"></i>Kompakt</button>
            <button class="cat-btn" onclick="filterCars(this,'Economy')"><i class="bi bi-fuel-pump me-1"></i>Ekonomi</button>
        </div>
    </div>
</div>

<!-- CARS -->
<section id="cars-section" class="py-5">
    <div class="container">
        <div class="d-flex align-items-end justify-content-between mb-4">
            <div>
                <h2 class="section-title mb-0">Musait <span>Araclar</span></h2>
                <div class="section-divider"></div>
            </div>
            <span class="text-muted small" id="car-count">@Model.Count arac listeleniyor</span>
        </div>
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-car-front display-1 text-muted"></i>
                <p class="text-muted mt-3">Su an musait arac bulunmuyor.</p>
            </div>
        }
        else
        {
            <div class="row g-4" id="cars-grid">
                @foreach (var car in Model)
                {
                    <div class="col-lg-3 col-md-4 col-sm-6 car-item" data-category="@car.Category">
                        <div class="car-card h-100">
                            <div class="car-img-wrap">
                                @if (!string.IsNullOrEmpty(car.ImageUrl))
                                {
                                    <img src="@car.ImageUrl" alt="@car.Brand @car.Model" class="car-img"
                                         onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                                    <div class="car-no-img" style="display:none">
                                        <i class="bi bi-car-front-fill"></i>
                                        <span>@car.Brand @car.Model</span>
                                    </div>
                                }
                                else
                                {
                                    <div class="car-no-img">
                                        <i class="bi bi-car-front-fill"></i>
                                        <span>@car.Brand @car.Model</span>
                                    </div>
                                }
                                <span class="car-cat-badge">@car.Category</span>
                            </div>
                            <div class="p-3">
                                <h6 class="fw-bold mb-1">@car.Brand @car.Model</h6>
                                <p class="text-muted small mb-3">@car.Year</p>
                                <div class="car-features mb-3">
                                    <span class="car-feature"><i class="bi bi-people-fill"></i> @car.Seats Kisi</span>
                                    <span class="car-feature"><i class="bi bi-gear-fill"></i> @(car.Transmission ?? "Otomatik")</span>
                                    <span class="car-feature"><i class="bi bi-fuel-pump-fill"></i> @(car.FuelType ?? "Benzin")</span>
                                    <span class="car-feature"><i class="bi bi-snow"></i> Klima</span>
                                </div>
                                <div class="d-flex align-items-center justify-content-between">
                                    <div>
                                        <span class="price-tag fs-5">&#8378;@car.PricePerDay.ToString("N0")</span>
                                        <span class="text-muted small">/gun</span>
                                    </div>
                                    <button class="btn btn-primary btn-sm px-3"
                                            onclick="openBookingModal(@car.Id, '@car.Brand @car.Model', @car.PricePerDay)">
                                        Kirala
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>
<!-- WHY US -->
<section class="py-5" style="background:#f8f9fa">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title">Neden <span>Bizi</span> Secmelisiniz?</h2>
            <div class="section-divider mx-auto"></div>
        </div>
        <div class="row g-4">
            <div class="col-md-3 col-sm-6"><div class="why-card"><div class="icon-wrap"><i class="bi bi-shield-check"></i></div><h6 class="fw-bold">Guvenli Araclar</h6><p class="text-muted small mb-0">Tum araclarimiz duzenli bakimdan gecer, sigortalidir.</p></div></div>
            <div class="col-md-3 col-sm-6"><div class="why-card"><div class="icon-wrap"><i class="bi bi-lightning-charge"></i></div><h6 class="fw-bold">Aninda Onay</h6><p class="text-muted small mb-0">Rezervasyonunuz saniyeler icinde onaylanir.</p></div></div>
            <div class="col-md-3 col-sm-6"><div class="why-card"><div class="icon-wrap"><i class="bi bi-cash-coin"></i></div><h6 class="fw-bold">En Iyi Fiyat</h6><p class="text-muted small mb-0">Piyasanin en rekabetci fiyatlarini sunuyoruz.</p></div></div>
            <div class="col-md-3 col-sm-6"><div class="why-card"><div class="icon-wrap"><i class="bi bi-headset"></i></div><h6 class="fw-bold">7/24 Destek</h6><p class="text-muted small mb-0">Her an yanimizdayiz, sorunlarinizi hizla cozuyoruz.</p></div></div>
        </div>
    </div>
</section>

<!-- REVIEWS -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title">Musteri <span>Yorumlari</span></h2>
            <div class="section-divider mx-auto"></div>
        </div>
        <div class="row g-4">
            <div class="col-md-4"><div class="review-card"><div class="review-stars mb-2">&#9733;&#9733;&#9733;&#9733;&#9733;</div><p class="mb-3 text-muted small">"Porsche Cayenne'yi kiraladim, arac mukemmeldi."</p><div class="d-flex align-items-center gap-2"><div class="reviewer-avatar">AK</div><div><div class="fw-bold small">Ahmet K.</div><div class="text-muted" style="font-size:.75rem">Premium Musteri</div></div></div></div></div>
            <div class="col-md-4"><div class="review-card"><div class="review-stars mb-2">&#9733;&#9733;&#9733;&#9733;&#9733;</div><p class="mb-3 text-muted small">"Fiyatlar cok uygun, araclar temiz ve bakimli."</p><div class="d-flex align-items-center gap-2"><div class="reviewer-avatar">SY</div><div><div class="fw-bold small">Selin Y.</div><div class="text-muted" style="font-size:.75rem">Duzenli Musteri</div></div></div></div></div>
            <div class="col-md-4"><div class="review-card"><div class="review-stars mb-2">&#9733;&#9733;&#9733;&#9733;&#9734;</div><p class="mb-3 text-muted small">"Online rezervasyon cok kolay, arac tam zamaninda hazirdi."</p><div class="d-flex align-items-center gap-2"><div class="reviewer-avatar">MO</div><div><div class="fw-bold small">Murat O.</div><div class="text-muted" style="font-size:.75rem">Is Seyahati</div></div></div></div></div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="py-5" style="background:var(--dark-bg)">
    <div class="container text-center">
        <h2 class="text-white fw-bold mb-3">Hemen Rezervasyon Yap</h2>
        <p class="text-white-50 mb-4">Ucretsiz uyelik ile tum araclara aninda erisim sagla.</p>
        <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg px-5">
            <i class="bi bi-person-plus me-2"></i>Ucretsiz Kayit Ol
        </a>
    </div>
</section>

<!-- BOOKING MODAL -->
<div class="modal fade" id="bookingModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0" style="border-radius:4px">
            <div class="modal-header" style="background:var(--dark-bg);border-radius:4px 4px 0 0">
                <h5 class="modal-title text-white fw-bold">
                    <i class="bi bi-calendar-check me-2" style="color:var(--primary)"></i>
                    <span id="modal-car-name">Arac Kiralama</span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="alert alert-danger d-none" id="booking-error"></div>
                <div class="alert alert-success d-none" id="booking-success"></div>
                <div class="row g-3">
                    <div class="col-6">
                        <label class="form-label fw-semibold small">Baslangic Tarihi</label>
                        <input type="date" class="form-control" id="modal-start-date">
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-semibold small">Bitis Tarihi</label>
                        <input type="date" class="form-control" id="modal-end-date">
                    </div>
                    <div class="col-12">
                        <div class="p-3 rounded" style="background:#fff4ee;border-left:4px solid var(--primary)">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-semibold">Toplam Tutar</span>
                                <span class="price-tag fs-5 fw-bold" id="modal-total">&#8378;0</span>
                            </div>
                            <div class="text-muted small mt-1" id="modal-days-info">Tarih seciniz</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Iptal</button>
                <button type="button" class="btn btn-primary px-4" id="confirm-booking-btn" onclick="submitBooking()">
                    <i class="bi bi-check-circle me-1"></i>Rezervasyonu Onayla
                </button>
            </div>
        </div>
    </div>
</div>
@section Scripts {
<style>
    .search-box{background:#fff;border-radius:4px;padding:2rem;box-shadow:0 8px 40px rgba(0,0,0,.3)}
    .search-label{font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#333;display:block;margin-bottom:6px}
    .search-tab{background:#f1f5f9;border:none;border-radius:4px;padding:8px 18px;font-weight:600;font-size:.875rem;color:#555;cursor:pointer;transition:all .2s}
    .search-tab.active{background:var(--primary);color:#fff}
    .cat-btn{background:transparent;border:2px solid #e2e8f0;border-radius:50px;padding:6px 18px;font-weight:600;font-size:.85rem;color:#555;cursor:pointer;transition:all .2s;white-space:nowrap}
    .cat-btn.active,.cat-btn:hover{background:var(--primary);border-color:var(--primary);color:#fff}
    .car-img-wrap{position:relative;height:200px;overflow:hidden;background:#1a1a1a}
    .car-img{width:100%;height:100%;object-fit:cover;transition:transform .4s}
    .car-card:hover .car-img{transform:scale(1.05)}
    .car-no-img{width:100%;height:100%;background:linear-gradient(135deg,#1a1a1a,#2d2d2d);display:flex;flex-direction:column;align-items:center;justify-content:center;color:#fff;gap:8px}
    .car-no-img i{font-size:3rem;color:var(--primary)}
    .car-no-img span{font-size:.85rem;font-weight:600;color:#ccc;text-align:center;padding:0 1rem}
    .car-cat-badge{position:absolute;top:10px;left:10px;background:var(--primary);color:#fff;font-size:.7rem;font-weight:700;text-transform:uppercase;padding:3px 10px;border-radius:50px}
    .car-features{display:flex;flex-wrap:wrap;gap:6px}
    .car-feature{background:#f1f5f9;border-radius:50px;padding:3px 10px;font-size:.75rem;color:#555;display:flex;align-items:center;gap:4px}
    .car-feature i{color:var(--primary)}
    .reviewer-avatar{width:40px;height:40px;border-radius:50%;background:var(--primary);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.85rem;flex-shrink:0}
    .input-group-text{height:48px}
    .input-group .form-control{height:48px}
</style>
<script>
    var currentCarId=0,currentPrice=0;
    (function(){
        var t=new Date(),s=new Date(t),e=new Date(t);
        s.setDate(t.getDate()+1);e.setDate(t.getDate()+7);
        var fmt=function(d){return d.toISOString().split("T")[0];};
        document.getElementById("startDate").value=fmt(s);
        document.getElementById("endDate").value=fmt(e);
    })();
    function setTab(type){
        document.getElementById("tab-daily").classList.toggle("active",type==="daily");
        document.getElementById("tab-monthly").classList.toggle("active",type==="monthly");
    }
    function scrollToCars(){document.getElementById("cars-section").scrollIntoView({behavior:"smooth"});}
    function filterCars(btn,cat){
        document.querySelectorAll(".cat-btn").forEach(function(b){b.classList.remove("active");});
        btn.classList.add("active");
        var items=document.querySelectorAll(".car-item"),count=0;
        items.forEach(function(item){
            var show=cat==="all"||item.dataset.category===cat;
            item.style.display=show?"":"none";
            if(show)count++;
        });
        document.getElementById("car-count").textContent=count+" arac listeleniyor";
    }
    function openBookingModal(carId,carName,price){
        var token="@Html.Raw(Context.Session.GetString("JwtToken") ?? "")";
        if(!token){window.location.href="/Account/Login";return;}
        currentCarId=carId;currentPrice=price;
        document.getElementById("modal-car-name").textContent=carName;
        document.getElementById("booking-error").classList.add("d-none");
        document.getElementById("booking-success").classList.add("d-none");
        var t=new Date(),s=new Date(t),e=new Date(t);
        s.setDate(t.getDate()+1);e.setDate(t.getDate()+7);
        var fmt=function(d){return d.toISOString().split("T")[0];};
        document.getElementById("modal-start-date").value=fmt(s);
        document.getElementById("modal-end-date").value=fmt(e);
        calcPrice();
        new bootstrap.Modal(document.getElementById("bookingModal")).show();
    }
    function calcPrice(){
        var sd=document.getElementById("modal-start-date").value;
        var ed=document.getElementById("modal-end-date").value;
        if(!sd||!ed)return;
        var days=Math.max(1,Math.round((new Date(ed)-new Date(sd))/86400000));
        var total=days*currentPrice;
        document.getElementById("modal-total").textContent="&#8378;"+total.toLocaleString("tr-TR");
        document.getElementById("modal-days-info").textContent=days+" gun x &#8378;"+currentPrice.toLocaleString("tr-TR")+"/gun";
    }
    document.addEventListener("DOMContentLoaded",function(){
        document.getElementById("modal-start-date").addEventListener("change",calcPrice);
        document.getElementById("modal-end-date").addEventListener("change",calcPrice);
    });
    function submitBooking(){
        var sd=document.getElementById("modal-start-date").value;
        var ed=document.getElementById("modal-end-date").value;
        var errEl=document.getElementById("booking-error");
        var sucEl=document.getElementById("booking-success");
        errEl.classList.add("d-none");sucEl.classList.add("d-none");
        if(!sd||!ed||new Date(ed)<=new Date(sd)){
            errEl.textContent="Lutfen gecerli tarih araligi seciniz.";
            errEl.classList.remove("d-none");return;
        }
        var btn=document.getElementById("confirm-booking-btn");
        btn.disabled=true;
        btn.innerHTML="<span class=\"spinner-border spinner-border-sm me-1\"></span>Isleniyor...";
        $.ajax({
            url:"/Booking/Create",method:"POST",contentType:"application/json",
            data:JSON.stringify({carId:currentCarId,startDate:sd,endDate:ed}),
            success:function(res){
                sucEl.textContent="Rezervasyonunuz basariyla olusturuldu!";
                sucEl.classList.remove("d-none");
                btn.disabled=false;
                btn.innerHTML="<i class=\"bi bi-check-circle me-1\"></i>Rezervasyonu Onayla";
                setTimeout(function(){bootstrap.Modal.getInstance(document.getElementById("bookingModal")).hide();},2000);
            },
            error:function(xhr){
                var msg=(xhr.responseJSON&&xhr.responseJSON.message)?xhr.responseJSON.message:"Rezervasyon olusturulamadi.";
                errEl.textContent=msg;errEl.classList.remove("d-none");
                btn.disabled=false;
                btn.innerHTML="<i class=\"bi bi-check-circle me-1\"></i>Rezervasyonu Onayla";
            }
        });
    }
</script>
}