<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RentACar</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <style>
        :root {
            --primary: #ff6600;
            --primary-dark: #e55a00;
            --dark-bg: #111111;
            --dark-secondary: #1a1a1a;
            --card-shadow: 0 4px 20px rgba(0,0,0,.08);
            --text-muted: #6b7280;
        }

        body { background-color: #f5f5f5; font-family: 'Segoe UI', sans-serif; }

        /* Navbar */
        .navbar { background: var(--dark-bg) !important; padding: 0.75rem 0; border-bottom: 3px solid var(--primary); }
        .navbar-brand { font-weight: 900; font-size: 1.6rem; letter-spacing: -1px; color: #fff !important; }
        .navbar-brand span { color: var(--primary); }
        .nav-link { font-weight: 500; transition: color .2s; }
        .nav-link:hover { color: var(--primary) !important; }
        .nav-user-badge {
            background: rgba(255,255,255,.1);
            border-radius: 20px;
            padding: 4px 14px;
            font-size: .875rem;
        }

        /* Cards */
        .car-card {
            border: none;
            border-radius: 4px;
            box-shadow: var(--card-shadow);
            transition: transform .25s, box-shadow .25s;
            overflow: hidden;
            background: #fff;
        }
        .car-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 32px rgba(0,0,0,.14);
        }
        .car-card .card-img-placeholder {
            height: 200px;
            background: linear-gradient(135deg, #1a1a1a, #333);
            display: flex; align-items: center; justify-content: center;
        }

        /* Hero */
        .hero-section {
            background: var(--dark-bg);
            position: relative; overflow: hidden;
            min-height: 520px;
        }
        .hero-section::after {
            content: '';
            position: absolute;
            bottom: 0; left: 0; right: 0;
            height: 4px;
            background: var(--primary);
        }

        /* Search Box */
        .search-box {
            background: #fff;
            border-radius: 4px;
            padding: 2rem;
            box-shadow: 0 8px 40px rgba(0,0,0,.3);
        }
        .search-box .form-control,
        .search-box .form-select {
            border-radius: 2px;
            border: 1px solid #ddd;
            height: 52px;
            font-size: .95rem;
        }
        .search-box .btn-search {
            background: var(--primary);
            color: #fff;
            border: none;
            border-radius: 2px;
            height: 52px;
            font-weight: 700;
            font-size: 1rem;
            letter-spacing: .5px;
            transition: background .2s;
        }
        .search-box .btn-search:hover { background: var(--primary-dark); color: #fff; }
        .search-box label { font-size: .8rem; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; color: #333; margin-bottom: 6px; }

        /* Stat cards */
        .stat-card {
            border: none; border-radius: 4px;
            box-shadow: var(--card-shadow);
        }

        /* Why us section */
        .why-card {
            background: #fff;
            border-radius: 4px;
            padding: 2rem;
            text-align: center;
            box-shadow: var(--card-shadow);
            transition: transform .2s;
        }
        .why-card:hover { transform: translateY(-4px); }
        .why-card .icon-wrap {
            width: 64px; height: 64px;
            background: #fff4ee;
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 1rem;
            font-size: 1.6rem;
            color: var(--primary);
        }

        /* Review cards */
        .review-card {
            background: #fff;
            border-radius: 4px;
            padding: 1.5rem;
            box-shadow: var(--card-shadow);
            border-left: 4px solid var(--primary);
        }
        .review-stars { color: var(--primary); }

        /* Section title */
        .section-title { font-weight: 800; font-size: 1.75rem; }
        .section-title span { color: var(--primary); }
        .section-divider {
            width: 48px; height: 4px;
            background: var(--primary);
            border-radius: 2px;
            margin: .75rem 0 1.5rem;
        }

        /* Admin sidebar */
        .admin-sidebar {
            background: var(--dark-bg);
            min-height: calc(100vh - 60px);
            padding: 1.5rem 0;
        }
        .admin-sidebar .nav-link {
            color: #94a3b8;
            padding: .6rem 1.5rem;
            border-radius: 0;
            font-size: .9rem;
        }
        .admin-sidebar .nav-link:hover,
        .admin-sidebar .nav-link.active {
            color: #fff;
            background: rgba(255,102,0,.15);
            border-left: 3px solid var(--primary);
        }
        .admin-sidebar .nav-link i { width: 20px; }

        /* Badges */
        .badge-available { background: #dcfce7; color: #166534; }
        .badge-rented    { background: #fee2e2; color: #991b1b; }
        .badge-maintenance { background: #fef9c3; color: #854d0e; }
        .badge-pending   { background: #fef3c7; color: #92400e; }
        .badge-confirmed { background: #dcfce7; color: #166534; }
        .badge-cancelled { background: #fee2e2; color: #991b1b; }
        .badge-completed { background: #e0e7ff; color: #3730a3; }

        /* Table */
        .table-card { border: none; border-radius: 4px; box-shadow: var(--card-shadow); overflow: hidden; }
        .table thead th { background: #f1f5f9; font-weight: 700; font-size: .8rem; text-transform: uppercase; letter-spacing: .5px; border: none; }
        .table td { vertical-align: middle; border-color: #f1f5f9; }

        /* Forms */
        .form-control, .form-select {
            border-radius: 4px;
            border-color: #e2e8f0;
            padding: .6rem 1rem;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(255,102,0,.12);
        }

        /* Buttons */
        .btn { border-radius: 4px; font-weight: 600; }
        .btn-primary { background: var(--primary); border-color: var(--primary); }
        .btn-primary:hover { background: var(--primary-dark); border-color: var(--primary-dark); }
        .btn-outline-primary { color: var(--primary); border-color: var(--primary); }
        .btn-outline-primary:hover { background: var(--primary); border-color: var(--primary); }

        /* Page header */
        .page-header {
            background: #fff;
            border-bottom: 1px solid #e2e8f0;
            padding: 1.25rem 0;
            margin-bottom: 2rem;
        }

        /* Footer */
        footer { background: var(--dark-bg) !important; border-top: 3px solid var(--primary); }

        /* Car price tag */
        .price-tag { color: var(--primary); font-weight: 800; }

        /* Animations */
        .fade-in { animation: fadeIn .4s ease; }
        @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container">
        <a class="navbar-brand text-white" asp-controller="Home" asp-action="Index">
            <i class="bi bi-car-front-fill me-2" style="color:var(--primary)"></i>RENT<span>A</span>CAR
        </a>
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto gap-1">
                <li class="nav-item">
                    <a class="nav-link text-white-50" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-house me-1"></i>Ana Sayfa
                    </a>
                </li>
                @if (!string.IsNullOrEmpty(Context.Session.GetString("JwtToken")) &&
                     !(Context.Session.GetString("UserRoles")?.Contains("Admin") == true))
                {
                    <li class="nav-item">
                        <a class="nav-link text-white-50" asp-controller="Booking" asp-action="MyBookings">
                            <i class="bi bi-calendar-check me-1"></i>Rezervasyonlarım
                        </a>
                    </li>
                }
                @if (Context.Session.GetString("UserRoles")?.Contains("Admin") == true)
                {
                    <li class="nav-item">
                        <a class="nav-link text-white-50" asp-controller="Admin" asp-action="Index">
                            <i class="bi bi-speedometer2 me-1"></i>Admin Panel
                        </a>
                    </li>
                }
            </ul>
            <ul class="navbar-nav align-items-center gap-2">
                @if (!string.IsNullOrEmpty(Context.Session.GetString("JwtToken")))
                {
                    <li class="nav-item">
                        <span class="nav-user-badge text-white">
                            <i class="bi bi-person-circle me-1 text-info"></i>
                            @Context.Session.GetString("UserFullName")
                        </span>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-sm btn-outline-danger" asp-controller="Account" asp-action="Logout">
                            <i class="bi bi-box-arrow-right me-1"></i>Çıkış
                        </a>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link text-white-50" asp-controller="Account" asp-action="Login">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Giriş
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-sm btn-primary" asp-controller="Account" asp-action="Register">
                            <i class="bi bi-person-plus me-1"></i>Kayıt Ol
                        </a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

<main class="fade-in">
    @RenderBody()
</main>

<footer class="text-light py-5 mt-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <h5 class="fw-bold mb-3">
                    <i class="bi bi-car-front-fill me-2" style="color:var(--primary)"></i>RENTACAR
                </h5>
                <p class="text-white-50 small">Güvenli, hızlı ve uygun fiyatlı araç kiralama hizmeti.</p>
            </div>
            <div class="col-md-4">
                <h6 class="fw-semibold mb-3 text-white-50 text-uppercase" style="font-size:.75rem;letter-spacing:1px">Hızlı Erişim</h6>
                <ul class="list-unstyled small">
                    <li><a asp-controller="Home" asp-action="Index" class="text-white-50 text-decoration-none">Ana Sayfa</a></li>
                    <li><a asp-controller="Account" asp-action="Login" class="text-white-50 text-decoration-none">Giriş Yap</a></li>
                    <li><a asp-controller="Account" asp-action="Register" class="text-white-50 text-decoration-none">Kayıt Ol</a></li>
                </ul>
            </div>
            <div class="col-md-4">
                <h6 class="fw-semibold mb-3 text-white-50 text-uppercase" style="font-size:.75rem;letter-spacing:1px">İletişim</h6>
                <p class="text-white-50 small mb-1"><i class="bi bi-envelope me-2"></i>info@rentacar.com</p>
                <p class="text-white-50 small"><i class="bi bi-telephone me-2"></i>0850 123 45 67</p>
            </div>
        </div>
        <hr class="border-secondary mt-4" />
        <p class="text-center text-white-50 small mb-0">&copy; 2024 RentACar. Tüm hakları saklıdır.</p>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
