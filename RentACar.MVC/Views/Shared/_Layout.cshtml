<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RentACar</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <style>
        :root {
            --primary: #0d6efd;
            --dark-bg: #0f172a;
            --card-shadow: 0 4px 20px rgba(0,0,0,.08);
        }

        body { background-color: #f8fafc; font-family: 'Segoe UI', sans-serif; }

        /* Navbar */
        .navbar { background: var(--dark-bg) !important; padding: 0.75rem 0; }
        .navbar-brand { font-weight: 800; font-size: 1.4rem; letter-spacing: -0.5px; }
        .navbar-brand span { color: #3b82f6; }
        .nav-link { font-weight: 500; transition: color .2s; }
        .nav-link:hover { color: #93c5fd !important; }
        .nav-user-badge {
            background: rgba(255,255,255,.1);
            border-radius: 20px;
            padding: 4px 14px;
            font-size: .875rem;
        }

        /* Cards */
        .car-card {
            border: none;
            border-radius: 16px;
            box-shadow: var(--card-shadow);
            transition: transform .25s, box-shadow .25s;
            overflow: hidden;
        }
        .car-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 32px rgba(0,0,0,.14);
        }
        .car-card .card-img-placeholder {
            height: 200px;
            background: linear-gradient(135deg, #1e293b, #334155);
            display: flex; align-items: center; justify-content: center;
        }

        /* Hero */
        .hero-section {
            background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 50%, #0f3460 100%);
            position: relative; overflow: hidden;
        }
        .hero-section::before {
            content: '';
            position: absolute; inset: 0;
            background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        }

        /* Stat cards */
        .stat-card {
            border: none; border-radius: 16px;
            box-shadow: var(--card-shadow);
        }

        /* Admin sidebar */
        .admin-sidebar {
            background: var(--dark-bg);
            min-height: calc(100vh - 60px);
            padding: 1.5rem 0;
        }
        .admin-sidebar .nav-link {
            color: #94a3b8;
            padding: .6rem 1.5rem;
            border-radius: 0;
            font-size: .9rem;
        }
        .admin-sidebar .nav-link:hover,
        .admin-sidebar .nav-link.active {
            color: #fff;
            background: rgba(255,255,255,.08);
        }
        .admin-sidebar .nav-link i { width: 20px; }

        /* Badges */
        .badge-available { background: #dcfce7; color: #166534; }
        .badge-rented    { background: #fee2e2; color: #991b1b; }
        .badge-maintenance { background: #fef9c3; color: #854d0e; }
        .badge-pending   { background: #fef3c7; color: #92400e; }
        .badge-confirmed { background: #dcfce7; color: #166534; }
        .badge-cancelled { background: #fee2e2; color: #991b1b; }
        .badge-completed { background: #e0e7ff; color: #3730a3; }

        /* Table */
        .table-card { border: none; border-radius: 16px; box-shadow: var(--card-shadow); overflow: hidden; }
        .table thead th { background: #f1f5f9; font-weight: 600; font-size: .85rem; text-transform: uppercase; letter-spacing: .5px; border: none; }
        .table td { vertical-align: middle; border-color: #f1f5f9; }

        /* Forms */
        .form-control, .form-select {
            border-radius: 10px;
            border-color: #e2e8f0;
            padding: .6rem 1rem;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(13,110,253,.12);
        }

        /* Buttons */
        .btn { border-radius: 10px; font-weight: 500; }
        .btn-primary { background: #2563eb; border-color: #2563eb; }
        .btn-primary:hover { background: #1d4ed8; border-color: #1d4ed8; }

        /* Page header */
        .page-header {
            background: #fff;
            border-bottom: 1px solid #e2e8f0;
            padding: 1.25rem 0;
            margin-bottom: 2rem;
        }

        /* Footer */
        footer { background: var(--dark-bg) !important; }

        /* Animations */
        .fade-in { animation: fadeIn .4s ease; }
        @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container">
        <a class="navbar-brand text-white" asp-controller="Home" asp-action="Index">
            <i class="bi bi-car-front-fill me-2" style="color:#3b82f6"></i>Rent<span>A</span>Car
        </a>
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto gap-1">
                <li class="nav-item">
                    <a class="nav-link text-white-50" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-house me-1"></i>Ana Sayfa
                    </a>
                </li>
                @if (!string.IsNullOrEmpty(Context.Session.GetString("JwtToken")) &&
                     !(Context.Session.GetString("UserRoles")?.Contains("Admin") == true))
                {
                    <li class="nav-item">
                        <a class="nav-link text-white-50" asp-controller="Booking" asp-action="MyBookings">
                            <i class="bi bi-calendar-check me-1"></i>Rezervasyonlarım
                        </a>
                    </li>
                }
                @if (Context.Session.GetString("UserRoles")?.Contains("Admin") == true)
                {
                    <li class="nav-item">
                        <a class="nav-link text-white-50" asp-controller="Admin" asp-action="Index">
                            <i class="bi bi-speedometer2 me-1"></i>Admin Panel
                        </a>
                    </li>
                }
            </ul>
            <ul class="navbar-nav align-items-center gap-2">
                @if (!string.IsNullOrEmpty(Context.Session.GetString("JwtToken")))
                {
                    <li class="nav-item">
                        <span class="nav-user-badge text-white">
                            <i class="bi bi-person-circle me-1 text-info"></i>
                            @Context.Session.GetString("UserFullName")
                        </span>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-sm btn-outline-danger" asp-controller="Account" asp-action="Logout">
                            <i class="bi bi-box-arrow-right me-1"></i>Çıkış
                        </a>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link text-white-50" asp-controller="Account" asp-action="Login">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Giriş
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-sm btn-primary" asp-controller="Account" asp-action="Register">
                            <i class="bi bi-person-plus me-1"></i>Kayıt Ol
                        </a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

<main class="fade-in">
    @RenderBody()
</main>

<footer class="text-light py-5 mt-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <h5 class="fw-bold mb-3">
                    <i class="bi bi-car-front-fill me-2" style="color:#3b82f6"></i>RentACar
                </h5>
                <p class="text-white-50 small">Güvenli, hızlı ve uygun fiyatlı araç kiralama hizmeti.</p>
            </div>
            <div class="col-md-4">
                <h6 class="fw-semibold mb-3 text-white-50 text-uppercase" style="font-size:.75rem;letter-spacing:1px">Hızlı Erişim</h6>
                <ul class="list-unstyled small">
                    <li><a asp-controller="Home" asp-action="Index" class="text-white-50 text-decoration-none">Ana Sayfa</a></li>
                    <li><a asp-controller="Account" asp-action="Login" class="text-white-50 text-decoration-none">Giriş Yap</a></li>
                    <li><a asp-controller="Account" asp-action="Register" class="text-white-50 text-decoration-none">Kayıt Ol</a></li>
                </ul>
            </div>
            <div class="col-md-4">
                <h6 class="fw-semibold mb-3 text-white-50 text-uppercase" style="font-size:.75rem;letter-spacing:1px">İletişim</h6>
                <p class="text-white-50 small mb-1"><i class="bi bi-envelope me-2"></i>info@rentacar.com</p>
                <p class="text-white-50 small"><i class="bi bi-telephone me-2"></i>0850 123 45 67</p>
            </div>
        </div>
        <hr class="border-secondary mt-4" />
        <p class="text-center text-white-50 small mb-0">&copy; 2024 RentACar. Tüm hakları saklıdır.</p>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
