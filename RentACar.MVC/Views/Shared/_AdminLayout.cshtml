<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin | RentACar</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <style>
        :root { --sidebar-width: 240px; --dark-bg: #0f172a; }
        body { background: #f1f5f9; font-family: 'Segoe UI', sans-serif; }

        .admin-topbar {
            background: #fff;
            border-bottom: 1px solid #e2e8f0;
            height: 60px;
            position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
            display: flex; align-items: center; padding: 0 1.5rem;
            gap: 1rem;
        }
        .admin-topbar .brand { font-weight: 800; font-size: 1.2rem; color: #0f172a; }
        .admin-topbar .brand span { color: #2563eb; }

        .admin-sidebar {
            background: var(--dark-bg);
            width: var(--sidebar-width);
            position: fixed; top: 60px; left: 0; bottom: 0;
            overflow-y: auto; padding: 1rem 0;
            z-index: 999;
        }
        .admin-sidebar .nav-section {
            padding: .5rem 1rem .25rem;
            font-size: .7rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: 1px;
            color: #475569;
        }
        .admin-sidebar .nav-link {
            color: #94a3b8;
            padding: .6rem 1.25rem;
            font-size: .875rem; font-weight: 500;
            display: flex; align-items: center; gap: .6rem;
            border-radius: 0; transition: all .15s;
        }
        .admin-sidebar .nav-link:hover { color: #fff; background: rgba(255,255,255,.06); }
        .admin-sidebar .nav-link.active { color: #fff; background: rgba(37,99,235,.3); border-right: 3px solid #2563eb; }
        .admin-sidebar .nav-link i { font-size: 1rem; width: 18px; }

        .admin-content {
            margin-left: var(--sidebar-width);
            margin-top: 60px;
            padding: 2rem;
            min-height: calc(100vh - 60px);
        }

        /* Cards */
        .stat-card { border: none; border-radius: 16px; box-shadow: 0 2px 12px rgba(0,0,0,.06); }
        .table-card { border: none; border-radius: 16px; box-shadow: 0 2px 12px rgba(0,0,0,.06); overflow: hidden; }
        .table thead th { background: #f8fafc; font-size: .78rem; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; border: none; color: #64748b; }
        .table td { vertical-align: middle; border-color: #f1f5f9; font-size: .9rem; }
        .table tbody tr:hover { background: #f8fafc; }

        /* Badges */
        .badge-available  { background: #dcfce7; color: #166534; }
        .badge-rented     { background: #fee2e2; color: #991b1b; }
        .badge-maintenance{ background: #fef9c3; color: #854d0e; }
        .badge-pending    { background: #fef3c7; color: #92400e; }
        .badge-confirmed  { background: #dcfce7; color: #166534; }
        .badge-cancelled  { background: #fee2e2; color: #991b1b; }
        .badge-completed  { background: #e0e7ff; color: #3730a3; }

        .form-control, .form-select { border-radius: 10px; border-color: #e2e8f0; }
        .form-control:focus, .form-select:focus { border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37,99,235,.1); }
        .btn { border-radius: 10px; font-weight: 500; }

        @@media (max-width: 768px) {
            .admin-sidebar { display: none; }
            .admin-content { margin-left: 0; }
        }
    </style>
</head>
<body>

<!-- Top Bar -->
<div class="admin-topbar">
    <a href="/" class="brand text-decoration-none">
        <i class="bi bi-car-front-fill me-1" style="color:#2563eb"></i>Rent<span>A</span>Car
    </a>
    <span class="badge bg-danger ms-1" style="font-size:.65rem;">ADMIN</span>
    <div class="ms-auto d-flex align-items-center gap-3">
        <span class="text-muted small">
            <i class="bi bi-person-circle me-1"></i>
            @Context.Session.GetString("UserFullName")
        </span>
        <a asp-controller="Account" asp-action="Logout" class="btn btn-sm btn-outline-danger">
            <i class="bi bi-box-arrow-right me-1"></i>Çıkış
        </a>
    </div>
</div>

<!-- Sidebar -->
<nav class="admin-sidebar">
    <div class="nav-section">Genel</div>
    <a asp-controller="Admin" asp-action="Index"
       class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
        <i class="bi bi-speedometer2"></i>Dashboard
    </a>

    <div class="nav-section mt-3">Yönetim</div>
    <a asp-controller="Admin" asp-action="Cars"
       class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() is "Cars" or "CreateCar" or "EditCar" ? "active" : "")">
        <i class="bi bi-car-front"></i>Araçlar
    </a>
    <a asp-controller="Admin" asp-action="Bookings"
       class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Bookings" ? "active" : "")">
        <i class="bi bi-calendar-check"></i>Rezervasyonlar
    </a>

    <div class="nav-section mt-3">Diğer</div>
    <a asp-controller="Home" asp-action="Index" class="nav-link" target="_blank">
        <i class="bi bi-globe"></i>Siteyi Görüntüle
    </a>
</nav>

<!-- Content -->
<main class="admin-content">
    @RenderBody()
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
