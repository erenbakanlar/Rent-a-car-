@model List<RentACar.Application.DTOs.BookingDto>
@{
    ViewData["Title"] = "Rezervasyonlarım";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-1">Rezervasyonlarım</h3>
            <p class="text-muted mb-0">@Model.Count rezervasyon bulundu</p>
        </div>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
            <i class="bi bi-plus-lg me-2"></i>Yeni Rezervasyon
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show py-2 small">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-calendar-x text-muted" style="font-size:4rem"></i>
            <h5 class="mt-3 text-muted">Henüz rezervasyonunuz bulunmuyor.</h5>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3">
                <i class="bi bi-car-front me-2"></i>Araçlara Göz At
            </a>
        </div>
    }
    else
    {
        <!-- Özet kartlar -->
        <div class="row g-3 mb-4">
            @{
                var pending = Model.Count(b => b.Status == "Pending");
                var confirmed = Model.Count(b => b.Status == "Confirmed");
                var completed = Model.Count(b => b.Status == "Completed");
                var totalSpent = Model.Where(b => b.Status != "Cancelled").Sum(b => b.TotalPrice);
            }
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm text-center p-3" style="border-radius:14px;">
                    <div class="fw-bold fs-4 text-warning">@pending</div>
                    <div class="text-muted small">Beklemede</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm text-center p-3" style="border-radius:14px;">
                    <div class="fw-bold fs-4 text-success">@confirmed</div>
                    <div class="text-muted small">Onaylı</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm text-center p-3" style="border-radius:14px;">
                    <div class="fw-bold fs-4 text-secondary">@completed</div>
                    <div class="text-muted small">Tamamlanan</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm text-center p-3" style="border-radius:14px;">
                    <div class="fw-bold fs-4 text-primary">₺@totalSpent.ToString("N0")</div>
                    <div class="text-muted small">Toplam Harcama</div>
                </div>
            </div>
        </div>

        <!-- Rezervasyon kartları -->
        <div class="row g-3">
            @foreach (var b in Model.OrderByDescending(x => x.StartDate))
            {
                var (badgeClass, statusText, icon) = b.Status switch
                {
                    "Pending"   => ("badge-pending",   "Beklemede",   "hourglass-split"),
                    "Confirmed" => ("badge-confirmed", "Onaylandı",   "check-circle"),
                    "Cancelled" => ("badge-cancelled", "İptal Edildi","x-circle"),
                    "Completed" => ("badge-completed", "Tamamlandı",  "flag"),
                    _           => ("bg-secondary",    b.Status,      "circle")
                };
                var days = (b.EndDate - b.StartDate).Days;
                <div class="col-12 col-md-6">
                    <div class="card border-0 shadow-sm h-100" style="border-radius:16px; overflow:hidden;">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h6 class="fw-bold mb-1">@b.CarBrand @b.CarModel</h6>
                                    <span class="text-muted small">#@b.Id</span>
                                </div>
                                <span class="badge @badgeClass px-3 py-2 rounded-pill">
                                    <i class="bi bi-@icon me-1"></i>@statusText
                                </span>
                            </div>

                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <div class="p-2 rounded-3" style="background:#f8fafc;">
                                        <div class="text-muted" style="font-size:.7rem; text-transform:uppercase; letter-spacing:.5px;">Başlangıç</div>
                                        <div class="fw-semibold small">@b.StartDate.ToString("dd MMM yyyy")</div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="p-2 rounded-3" style="background:#f8fafc;">
                                        <div class="text-muted" style="font-size:.7rem; text-transform:uppercase; letter-spacing:.5px;">Bitiş</div>
                                        <div class="fw-semibold small">@b.EndDate.ToString("dd MMM yyyy")</div>
                                    </div>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="text-muted small">@days gün · </span>
                                    <span class="fw-bold text-primary">₺@b.TotalPrice.ToString("N2")</span>
                                </div>
                                @if (b.Status == "Pending")
                                {
                                    <button class="btn btn-sm btn-outline-danger btn-cancel"
                                            data-id="@b.Id"
                                            style="border-radius:8px;">
                                        <i class="bi bi-x-lg me-1"></i>İptal Et
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
<script>
    $('.btn-cancel').on('click', function () {
        const id = $(this).data('id');
        const $card = $(this).closest('.col-12');

        if (!confirm('Bu rezervasyonu iptal etmek istediğinize emin misiniz?')) return;

        $(this).prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span>');

        $.post('/Booking/Cancel', { id }, function (res) {
            if (res.success) {
                $card.fadeOut(300, function () { $(this).remove(); });
            } else {
                alert(res.message || 'İptal işlemi başarısız.');
            }
        });
    });
</script>
}
