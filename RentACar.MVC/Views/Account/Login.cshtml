@model RentACar.Application.DTOs.LoginDto
@{
    ViewData["Title"] = "Giriş Yap";
    Layout = null; // Auth sayfaları için tam sayfa layout
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giriş Yap - RentACar</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <style>
        :root { --primary: #ff6600; --primary-dark: #e55a00; }
        body { background: #f5f5f5; font-family: 'Segoe UI', sans-serif; }
        .auth-wrapper {
            min-height: 100vh;
            display: grid;
            grid-template-columns: 1fr 1fr;
        }
        .auth-left {
            background: #111;
            border-right: 4px solid var(--primary);
            display: flex; flex-direction: column;
            justify-content: center; align-items: center;
            padding: 3rem; color: white;
        }
        .auth-right {
            display: flex; align-items: center; justify-content: center;
            padding: 2rem;
        }
        .auth-card { width: 100%; max-width: 420px; }
        .form-control {
            border-radius: 4px; border-color: #ddd;
            padding: .7rem 1rem;
        }
        .form-control:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(255,102,0,.12);
        }
        .btn-auth {
            border-radius: 4px; padding: .75rem;
            font-weight: 700; font-size: 1rem;
            background: var(--primary); border-color: var(--primary); color: #fff;
        }
        .btn-auth:hover { background: var(--primary-dark); border-color: var(--primary-dark); color: #fff; }
        .input-group-text { border-radius: 4px 0 0 4px; background: #f8f8f8; border-color: #ddd; }
        .input-group .form-control { border-radius: 0 4px 4px 0; }
        a.text-primary { color: var(--primary) !important; }
        @@media (max-width: 768px) {
            .auth-wrapper { grid-template-columns: 1fr; }
            .auth-left { display: none; }
        }
    </style>
</head>
<body>
<div class="auth-wrapper">
    <!-- Sol panel -->
    <div class="auth-left">
        <div class="text-center">
            <i class="bi bi-car-front-fill mb-4" style="font-size:5rem; color:#ff6600;"></i>
            <h2 class="fw-bold mb-3">RentACar'a Hoş Geldiniz</h2>
            <p class="text-white-50 mb-4">Yüzlerce araç seçeneği, anlık rezervasyon ve güvenli ödeme sistemi.</p>
            <div class="d-flex flex-column gap-3 text-start">
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center"
                         style="width:40px;height:40px;background:rgba(255,255,255,.1)">
                        <i class="bi bi-shield-check text-info"></i>
                    </div>
                    <div>
                        <div class="fw-semibold">Güvenli Rezervasyon</div>
                        <div class="text-white-50 small">SSL şifreli güvenli ödeme</div>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center"
                         style="width:40px;height:40px;background:rgba(255,255,255,.1)">
                        <i class="bi bi-lightning-charge text-warning"></i>
                    </div>
                    <div>
                        <div class="fw-semibold">Anında Onay</div>
                        <div class="text-white-50 small">Saniyeler içinde rezervasyon</div>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center"
                         style="width:40px;height:40px;background:rgba(255,255,255,.1)">
                        <i class="bi bi-headset text-success"></i>
                    </div>
                    <div>
                        <div class="fw-semibold">7/24 Destek</div>
                        <div class="text-white-50 small">Her zaman yanınızdayız</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Sağ panel - Form -->
    <div class="auth-right">
        <div class="auth-card">
            <div class="mb-4">
                <a href="/" class="text-decoration-none text-muted small">
                    <i class="bi bi-arrow-left me-1"></i>Ana Sayfaya Dön
                </a>
            </div>

            <h3 class="fw-bold mb-1">Giriş Yap</h3>
            <p class="text-muted mb-4">Hesabınıza erişmek için bilgilerinizi girin.</p>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show py-2 small">
                    <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger py-2 small">
                    <i class="bi bi-exclamation-circle me-2"></i>@ViewBag.Error
                </div>
            }

            <form asp-action="Login" method="post">
                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-semibold small">E-posta Adresi</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-envelope text-muted"></i></span>
                        <input asp-for="Email" class="form-control" placeholder="ornek@email.com" autocomplete="email" />
                    </div>
                </div>
                <div class="mb-4">
                    <label asp-for="Password" class="form-label fw-semibold small">Şifre</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock text-muted"></i></span>
                        <input asp-for="Password" type="password" class="form-control" id="passwordInput" placeholder="••••••••" autocomplete="current-password" />
                        <button type="button" class="btn btn-outline-secondary" id="togglePassword" style="border-radius:0 10px 10px 0;">
                            <i class="bi bi-eye" id="eyeIcon"></i>
                        </button>
                    </div>
                </div>
                <button type="submit" class="btn btn-primary w-100 btn-auth">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Giriş Yap
                </button>
            </form>

            <hr class="my-4" />
            <p class="text-center text-muted small mb-0">
                Hesabın yok mu?
                <a asp-action="Register" class="text-primary fw-semibold text-decoration-none">Kayıt Ol</a>
            </p>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
    document.getElementById('togglePassword').addEventListener('click', function () {
        const input = document.getElementById('passwordInput');
        const icon = document.getElementById('eyeIcon');
        if (input.type === 'password') {
            input.type = 'text';
            icon.className = 'bi bi-eye-slash';
        } else {
            input.type = 'password';
            icon.className = 'bi bi-eye';
        }
    });
</script>
</body>
</html>
