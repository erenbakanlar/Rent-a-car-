@model RentACar.Application.DTOs.RegisterDto
@{
    ViewData["Title"] = "Kayıt Ol";
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kayıt Ol - RentACar</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <style>
        :root { --primary: #ff6600; --primary-dark: #e55a00; }
        body { background: #f5f5f5; font-family: 'Segoe UI', sans-serif; }
        .auth-wrapper { min-height: 100vh; display: grid; grid-template-columns: 1fr 1fr; }
        .auth-left {
            background: #111;
            border-right: 4px solid var(--primary);
            display: flex; flex-direction: column;
            justify-content: center; align-items: center;
            padding: 3rem; color: white;
        }
        .auth-right { display: flex; align-items: center; justify-content: center; padding: 2rem; }
        .auth-card { width: 100%; max-width: 440px; }
        .form-control { border-radius: 4px; border-color: #ddd; padding: .7rem 1rem; }
        .form-control:focus { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(255,102,0,.12); }
        .btn-auth { border-radius: 4px; padding: .75rem; font-weight: 700; font-size: 1rem; background: var(--primary); border-color: var(--primary); color: #fff; }
        .btn-auth:hover { background: var(--primary-dark); border-color: var(--primary-dark); color: #fff; }
        .input-group-text { border-radius: 4px 0 0 4px; background: #f8f8f8; border-color: #ddd; }
        .input-group .form-control { border-radius: 0 4px 4px 0; }
        .strength-bar { height: 4px; border-radius: 2px; transition: all .3s; }
        a.text-primary { color: var(--primary) !important; }
        @@media (max-width: 768px) { .auth-wrapper { grid-template-columns: 1fr; } .auth-left { display: none; } }
    </style>
</head>
<body>
<div class="auth-wrapper">
    <div class="auth-left">
        <div class="text-center">
            <i class="bi bi-person-plus-fill mb-4" style="font-size:5rem; color:#ff6600;"></i>
            <h2 class="fw-bold mb-3">Aramıza Katılın</h2>
            <p class="text-white-50 mb-4">Ücretsiz hesap oluşturun ve hemen araç kiralamaya başlayın.</p>
            <div class="p-4 text-start" style="background:rgba(255,255,255,.07); border-radius:16px;">
                <p class="fw-semibold mb-3">Üye avantajları:</p>
                <ul class="list-unstyled text-white-50 small mb-0">
                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Anlık rezervasyon yapabilirsiniz</li>
                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Rezervasyon geçmişinizi takip edin</li>
                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Özel fiyat avantajlarından yararlanın</li>
                    <li><i class="bi bi-check-circle-fill text-success me-2"></i>7/24 müşteri desteği</li>
                </ul>
            </div>
        </div>
    </div>

    <div class="auth-right">
        <div class="auth-card">
            <div class="mb-4">
                <a href="/" class="text-decoration-none text-muted small">
                    <i class="bi bi-arrow-left me-1"></i>Ana Sayfaya Dön
                </a>
            </div>

            <h3 class="fw-bold mb-1">Hesap Oluştur</h3>
            <p class="text-muted mb-4">Bilgilerinizi girerek ücretsiz kayıt olun.</p>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger py-2 small">
                    <i class="bi bi-exclamation-circle me-2"></i>@ViewBag.Error
                </div>
            }

            <form asp-action="Register" method="post">
                <div class="mb-3">
                    <label asp-for="FullName" class="form-label fw-semibold small">Ad Soyad</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-person text-muted"></i></span>
                        <input asp-for="FullName" class="form-control" placeholder="Ad Soyad" autocomplete="name" />
                    </div>
                </div>
                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-semibold small">E-posta Adresi</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-envelope text-muted"></i></span>
                        <input asp-for="Email" class="form-control" placeholder="ornek@email.com" autocomplete="email" />
                    </div>
                </div>
                <div class="mb-2">
                    <label asp-for="Password" class="form-label fw-semibold small">Şifre</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock text-muted"></i></span>
                        <input asp-for="Password" type="password" class="form-control" id="passwordInput"
                               placeholder="En az 6 karakter" autocomplete="new-password"
                               oninput="checkStrength(this.value)" />
                        <button type="button" class="btn btn-outline-secondary" id="togglePassword" style="border-radius:0 10px 10px 0;">
                            <i class="bi bi-eye" id="eyeIcon"></i>
                        </button>
                    </div>
                </div>
                <!-- Şifre güç göstergesi -->
                <div class="mb-4">
                    <div class="d-flex gap-1 mb-1">
                        <div class="strength-bar flex-fill bg-secondary" id="s1"></div>
                        <div class="strength-bar flex-fill bg-secondary" id="s2"></div>
                        <div class="strength-bar flex-fill bg-secondary" id="s3"></div>
                        <div class="strength-bar flex-fill bg-secondary" id="s4"></div>
                    </div>
                    <small class="text-muted" id="strengthText">Şifre gücü</small>
                </div>

                <button type="submit" class="btn btn-primary w-100 btn-auth">
                    <i class="bi bi-person-check me-2"></i>Kayıt Ol
                </button>
            </form>

            <hr class="my-4" />
            <p class="text-center text-muted small mb-0">
                Zaten hesabın var mı?
                <a asp-action="Login" class="text-primary fw-semibold text-decoration-none">Giriş Yap</a>
            </p>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
    document.getElementById('togglePassword').addEventListener('click', function () {
        const input = document.getElementById('passwordInput');
        const icon = document.getElementById('eyeIcon');
        input.type = input.type === 'password' ? 'text' : 'password';
        icon.className = input.type === 'password' ? 'bi bi-eye' : 'bi bi-eye-slash';
    });

    function checkStrength(val) {
        let score = 0;
        if (val.length >= 6) score++;
        if (val.length >= 10) score++;
        if (/[A-Z]/.test(val) || /[0-9]/.test(val)) score++;
        if (/[^A-Za-z0-9]/.test(val)) score++;

        const colors = ['', '#ef4444', '#f97316', '#eab308', '#22c55e'];
        const labels = ['', 'Çok Zayıf', 'Zayıf', 'Orta', 'Güçlü'];
        for (let i = 1; i <= 4; i++) {
            document.getElementById('s' + i).style.background = i <= score ? colors[score] : '#e2e8f0';
        }
        document.getElementById('strengthText').textContent = val ? labels[score] || 'Çok Zayıf' : 'Şifre gücü';
        document.getElementById('strengthText').style.color = colors[score] || '#6b7280';
    }
</script>
</body>
</html>
